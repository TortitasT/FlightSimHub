[
  {
    "id": "dcs",
    "name": "DCS World",
    "kind": "sim",
    "exeName": "DCS.exe",
    "detection": {
      "registryKeys": [
        {
          "root": "HKCU",
          "path": "Software\\Eagle Dynamics\\DCS World",
          "value": "Path",
          "append": "bin/DCS.exe"
        },
        {
          "root": "HKCU",
          "path": "Software\\Eagle Dynamics\\DCS World OpenBeta",
          "value": "Path",
          "append": "bin/DCS.exe"
        }
      ],
      "wellKnownPaths": [
        "%ProgramFiles%/Eagle Dynamics/DCS World/bin/DCS.exe"
      ],
      "steamRelativeExe": "DCSWorld/bin/DCS.exe"
    },
    "source": {
      "type": "manual",
      "homepage": "https://www.digitalcombatsimulator.com/en/downloads/world/"
    }
  },
