<Window
  x:Class="FlightSimHubApp.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:muxc="using:Microsoft.UI.Xaml.Controls">
  <muxc:NavigationView
    x:Name="Navigation"
    PaneDisplayMode="Top"
    IsBackButtonVisible="Collapsed"
    IsSettingsVisible="False"
    SelectionChanged="OnNavigationChanged">
    <muxc:NavigationView.MenuItems>
      <muxc:NavigationViewItem x:Name="EnvironmentItem" Content="Environment" Tag="environment"/>
      <muxc:NavigationViewItem Content="Launchers" Tag="launchers"/>
    </muxc:NavigationView.MenuItems>
    <Frame x:Name="ContentFrame"/>
  </muxc:NavigationView>
</Window>
